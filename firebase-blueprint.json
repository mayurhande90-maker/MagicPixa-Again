{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core user profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "credits": { "type": "number" },
        "totalCreditsAcquired": { "type": "number" },
        "lifetimeGenerations": { "type": "number" },
        "plan": { "type": "string" },
        "signUpDate": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "storageTier": { "type": "string" },
        "referralCode": { "type": "string" },
        "referralCount": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "isBanned": { "type": "boolean" }
      },
      "required": ["uid", "name", "email"]
    },
    "Creation": {
      "title": "AI Creation",
      "description": "Data for an AI generated image",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "feature": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "storagePath": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Credit Transaction",
      "description": "Log of credit usage or acquisition",
      "type": "object",
      "properties": {
        "feature": { "type": "string" },
        "cost": { "type": "number" },
        "creditChange": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pricePaid": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/creations/{creationId}": {
      "schema": "Creation",
      "description": "User generated images"
    },
    "/users/{userId}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "User credit history"
    }
  }
}
